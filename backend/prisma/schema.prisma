generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  firstName String?
  lastName  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  pets     Pet[]
  devices  Device[]
}

model Pet {
  id                 Int      @id @default(autoincrement())
  userId             Int
  name               String
  species            String?
  breed              String?
  weight             Float?
  dietaryRestrictions String?
  imageUrl           String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  feedingSchedules FeedingSchedule[]
  feedingLogs      FeedingLog[]
}

model Device {
  id        Int      @id @default(autoincrement())
  userId    Int
  deviceId  String   @unique
  name      String?
  isOnline  Boolean  @default(false)
  lastSeen  DateTime?
  createdAt DateTime @default(now())

  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  feedingSchedules FeedingSchedule[]
  feedingLogs      FeedingLog[]
}

model FeedingSchedule {
  id          Int      @id @default(autoincrement())
  petId       Int
  deviceId    String
  time        String   // "08:00"
  portionSize Float
  isActive    Boolean  @default(true)
  feedingMode String   @default("scheduled") // "scheduled" or "free"
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  pet    Pet    @relation(fields: [petId], references: [id], onDelete: Cascade)
  device Device @relation(fields: [deviceId], references: [deviceId])
}

model FeedingLog {
  id             Int      @id @default(autoincrement())
  petId          Int?     // who was scheduled to eat
  actualPetId    Int?     // who actually ate (from recognition)
  deviceId       String
  scheduledGrams Float
  dispensedGrams Float
  consumedGrams  Float    @default(0)
  leftoverGrams  Float    @default(0)
  feedingType    String   // "scheduled", "manual", "free"
  status         String   @default("completed") // "completed", "failed", "pending"
  timestamp      DateTime @default(now())

  pet       Pet?    @relation(fields: [petId], references: [id])
  device    Device  @relation(fields: [deviceId], references: [deviceId])
}

model Notification {
  id        Int      @id @default(autoincrement())
  userId    Int
  message   String
  type      String   // "feeding_complete", "low_food", "feeding_failed"
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
}